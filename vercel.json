{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "qrheadstone.com" }],
      "destination": "https://www.qrheadstone.com/:path*",
      "permanent": true
    }
  ],
  "functions": {
    "api/server.ts": {
      "includeFiles": "dist/server/**",
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/ping",
      "schedule": "0 12 */5 * *"
    }
  ],
  "rewrites": [
    {
      "source": "/((?!assets/).*)",
      "destination": "/api/server"
    }
  ]
}
